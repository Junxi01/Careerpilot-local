### CareerPilot Local (example env)
### Copy to .env and fill values as features are implemented.

# --- MySQL ---
MYSQL_ROOT_PASSWORD=careerpilot_root_password
MYSQL_DATABASE=careerpilot
MYSQL_USER=careerpilot
MYSQL_PASSWORD=careerpilot_password

# --- Backend (planned) ---
BACKEND_PORT=8080

# --- Database (planned) ---
DB_HOST=mysql
DB_PORT=3306
DB_NAME=careerpilot
DB_USER=careerpilot
DB_PASSWORD=careerpilot_password

# --- AI provider (planned) ---
AI_MODE=mock
AI_API_BASE_URL=
AI_API_KEY=

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8080
